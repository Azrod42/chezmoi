return {
  {
    'tpope{{ .chezmoi.pathSeparator }}vim-dadbod',
    'kristijanhusak{{ .chezmoi.pathSeparator }}vim-dadbod-completion',
  },
  {
    'kristijanhusak{{ .chezmoi.pathSeparator }}vim-dadbod-ui',
    dependencies = {
      { 'tpope{{ .chezmoi.pathSeparator }}vim-dadbod', lazy = true },
      { 'kristijanhusak{{ .chezmoi.pathSeparator }}vim-dadbod-completion', ft = { 'sql', 'mysql', 'plsql' }, lazy = true },
    },
    cmd = {
      'DBUI',
      'DBUIToggle',
      'DBUIAddConnection',
      'DBUIFindBuffer',
    },
    init = function()
      -- Your DBUI configuration
      vim.o.foldenable = true
      vim.o.foldmethod = 'manual'
      vim.o.foldlevel = 99
      vim.g.db_ui_use_nerd_fonts = 1

      -- Set custom storage location for DBUI
      vim.g.db_ui_save_location = vim.fn.expand '~{{ .chezmoi.pathSeparator }}Sync{{ .chezmoi.pathSeparator }}work{{ .chezmoi.pathSeparator }}db_ui'
    end,
  },
}
