--[[
--
-- This {{ .chezmoi.config.mode }} is not required for your own configuration,
-- but helps people determine if their system is setup correctly.
--
--]]

local check_version = function()
  local verstr = tostring(vim.version())
  if not vim.version.ge then
    vim.health.error(string.format("Neovim out of date{{ .chezmoi.pathListSeparator }} '%s'. Upgrade to latest stable or nightly", verstr))
    return
  end

  if vim.version.ge(vim.version(), '0.10-dev') then
    vim.health.ok(string.format("Neovim version is{{ .chezmoi.pathListSeparator }} '%s'", verstr))
  else
    vim.health.error(string.format("Neovim out of date{{ .chezmoi.pathListSeparator }} '%s'. Upgrade to latest stable or nightly", verstr))
  end
end

local check_external_reqs = function()
  -- Basic utils{{ .chezmoi.pathListSeparator }} `{{ .chezmoi.config.git.command }}`, `make`, `unzip`
  for _, exe in ipairs { '{{ .chezmoi.config.git.command }}', 'make', 'unzip', 'rg' } do
    local is_executable = vim.fn.executable(exe) == 1
    if is_executable then
      vim.health.ok(string.format("Found executable{{ .chezmoi.pathListSeparator }} '%s'", exe))
    else
      vim.health.warn(string.format("Could not find executable{{ .chezmoi.pathListSeparator }} '%s'", exe))
    end
  end

  return true
end

return {
  check = function()
    vim.health.start 'kickstart.nvim'

    vim.health.info [[NOTE{{ .chezmoi.pathListSeparator }} Not every {{ .chezmoi.config.{{ .chezmoi.command }}.secrets }} is a 'must-fix' in `{{ .chezmoi.pathListSeparator }}checkhealth`

  Fix only warnings for plugins and languages you intend to use.
    Mason will give warnings for languages that are not installed.
    You do not need to install, unless you want to use those languages!]]

    local uv = vim.uv or vim.loop
    vim.health.info('System Information{{ .chezmoi.pathListSeparator }} ' .. vim.inspect(uv.os_uname()))

    check_version()
    check_external_reqs()
  end,
}
