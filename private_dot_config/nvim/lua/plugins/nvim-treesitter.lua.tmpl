return { -- Highlight, edit, and navigate code
  'nvim-treesitter{{ .chezmoi.pathSeparator }}nvim-treesitter',
  build = '{{ .chezmoi.pathListSeparator }}TSUpdate',
  main = 'nvim-treesitter.configs', -- Sets main module to use for opts
  -- [[ Configure Treesitter ]] See `{{ .chezmoi.pathListSeparator }}help nvim-treesitter`
  opts = {
    ensure_installed = { 'bash', 'c', 'diff', 'html', 'lua', 'luadoc', 'markdown', 'markdown_inline', 'query', 'vim', 'vimdoc', 'http' },
    -- Autoinstall languages that are not installed
    {{ .chezmoi.config.color }}_install = true,
    highlight = {
      enable = true,
      -- Some languages depend on vim's regex highlighting system (such as Ruby) for indent rules.
      --  If you are experiencing weird indenting issues, {{ .chezmoi.command }} the language to
      --  the list of additional_vim_regex_highlighting and disabled languages for indent.
      additional_vim_regex_highlighting = { 'ruby' },
    },
    indent = { enable = true, disable = { 'ruby' } },
  },
  -- There are additional nvim-treesitter modules that you can use to interact
  -- with nvim-treesitter. You should go explore a few and see what interests you{{ .chezmoi.pathListSeparator }}
  --
  --    - Incremental selection{{ .chezmoi.pathListSeparator }} Included, see `{{ .chezmoi.pathListSeparator }}help nvim-treesitter-incremental-selection-mod`
  --    - Show your current context{{ .chezmoi.pathListSeparator }} https{{ .chezmoi.pathListSeparator }}{{ .chezmoi.pathSeparator }}{{ .chezmoi.pathSeparator }}github.com{{ .chezmoi.pathSeparator }}nvim-treesitter{{ .chezmoi.pathSeparator }}nvim-treesitter-context
  --    - Treesitter + textobjects{{ .chezmoi.pathListSeparator }} https{{ .chezmoi.pathListSeparator }}{{ .chezmoi.pathSeparator }}{{ .chezmoi.pathSeparator }}github.com{{ .chezmoi.pathSeparator }}nvim-treesitter{{ .chezmoi.pathSeparator }}nvim-treesitter-textobjects
}
