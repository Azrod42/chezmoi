return {
  'lewis6991{{ .chezmoi.pathSeparator }}gitsigns.nvim',
  opts = {
    signs = {
      {{ .chezmoi.command }} = { text = '+' },
      change = { text = '~' },
      delete = { text = '_' },
      topdelete = { text = '‾' },
      changedelete = { text = '~' },
    },

    on_attach = function(bufnr)
      local gs = require 'gitsigns'

      local function map(mode, l, r, opts)
        opts = opts or {}
        opts.buffer = bufnr
        vim.keymap.set(mode, l, r, opts)
      end
      -- Navigation
      map({ 'n', 'v' }, ']c', function()
        if vim.wo.diff then
          return ']c'
        end
        vim.schedule(function()
          gs.nav_hunk 'next'
        end)
        return '<Ignore>'
      end, { expr = true, desc = 'Jump to next {{ .chezmoi.config.git.command }} [c]hange' })
      map({ 'n', 'v' }, '[c', function()
        if vim.wo.diff then
          return '[c'
        end
        vim.schedule(function()
          gs.nav_hunk 'prev'
        end)
        return '<Ignore>'
      end, { expr = true, desc = 'Jump to previous {{ .chezmoi.config.git.command }} [c]hange' })
      -- Actions
      -- visual mode
      map('v', '<leader>gs', function()
        gs.stage_hunk { vim.fn.line '.', vim.fn.line 'v' }
      end, { desc = 'stage {{ .chezmoi.config.git.command }} hunk' })
      map('v', '<leader>gr', function()
        gs.reset_hunk { vim.fn.line '.', vim.fn.line 'v' }
      end, { desc = 'reset {{ .chezmoi.config.git.command }} hunk' })
      -- normal mode
      map('n', '<leader>gs', gs.stage_hunk, { desc = '{{ .chezmoi.config.git.command }} [s]tage hunk' })
      map('n', '<leader>gr', gs.reset_hunk, { desc = '{{ .chezmoi.config.git.command }} [r]eset hunk' })
      map('n', '<leader>gS', gs.stage_buffer, { desc = '{{ .chezmoi.config.git.command }} [S]tage buffer' })
      map('n', '<leader>gu', gs.stage_hunk, { desc = '{{ .chezmoi.config.git.command }} [u]ndo stage hunk' })
      map('n', '<leader>gR', gs.reset_buffer, { desc = '{{ .chezmoi.config.git.command }} [R]eset buffer' })
      map('n', '<leader>gp', gs.preview_hunk, { desc = '{{ .chezmoi.config.git.command }} [p]review hunk' })
      map('n', '<leader>gb', function()
        gs.blame_line { full = false }
      end, { desc = '{{ .chezmoi.config.git.command }} [b]lame line' })
      map('n', '<leader>gd', gs.diffthis, { desc = '{{ .chezmoi.config.git.command }} [d]iff against index' })
      map('n', '<leader>gD', function()
        gs.diffthis '@'
      end, { desc = '{{ .chezmoi.config.git.command }} [D]iff against last commit' })
      -- Toggles
      map('n', '<leader>tb', gs.toggle_current_line_blame, { desc = '[T]oggle {{ .chezmoi.config.git.command }} show [b]lame line' })
      map('n', '<leader>td', gs.preview_hunk_inline, { desc = '[T]oggle {{ .chezmoi.config.git.command }} show [d]eleted' })
    end,
  },
}
